// Niri compositor config — migrated from Hyprland
// Docs: https://niri-wm.github.io/niri/Configuration:-Introduction

input {
    keyboard {
        xkb {
            layout "us"
        }
    }
    touchpad {
        tap
        natural-scroll
    }
    focus-follows-mouse
}

// ── Monitors ───────────────────────────────────────────────────
// 2560x1440, let Niri pick highest refresh rate
output "DP-2" {
    mode "2560x1440@165.000"
}

// ── Cursor ─────────────────────────────────────────────────────
cursor {
    xcursor-theme "catppuccin-latte-light-cursors"
    xcursor-size 24
}

// ── Environment ────────────────────────────────────────────────
environment {
    QT_QPA_PLATFORM "wayland"
    WAYLAND_DISPLAY "wayland-1"
    XDG_SESSION_TYPE "wayland"
    NIXOS_OZONE_WL "1"
}

// ── Appearance ─────────────────────────────────────────────────
layout {
    background-color "transparent"
    gaps 8
    focus-ring {
        off
    }
    border {
        on
        width 1
        active-color "#33ccff"
        inactive-color "#00000000"
    }
    center-focused-column "never"
    default-column-width { proportion 0.5; }
    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }
}
// ── Named workspaces ────────────────────────────────────────────
workspace "browser" {
    open-on-output "DP-2"
}
workspace "terminal" {
    open-on-output "DP-2"
}
workspace "scratch-1" {
    open-on-output "DP-2"
}
workspace "scratch-2" {
    open-on-output "DP-2"
}

// ── Spawn at startup ──────────────────────────────────────────
spawn-at-startup "waybar"
spawn-at-startup "mako"
spawn-at-startup "udiskie" "--notify" "--auto-mount"
spawn-at-startup "/home/julian/dotfiles/nixos/niri/start-swww.sh"
spawn-at-startup "/home/julian/dotfiles/nixos/niri/start-swaylock.sh"

hotkey-overlay {
    skip-at-startup
}

// ── Keybindings ────────────────────────────────────────────────
binds {
    // Essentials
    Super+Return { spawn "ghostty"; }
    Super+Space { spawn "wofi" "--show" "drun"; }
    Super+U { spawn "/home/julian/dotfiles/nixos/niri/open-usb.sh"; }
    Super+C { close-window; }
    Super+Shift+E { quit; }

    // Floating / fullscreen
    Super+V { toggle-window-floating; }
    Super+F { maximize-column; }
    Super+Shift+F { fullscreen-window; }

    // Focus movement
    Super+Left  { focus-column-left; }
    Super+Right { focus-column-right; }
    Super+Up    { focus-window-up; }
    Super+Down  { focus-window-down; }

    // Move windows
    Super+Shift+Left  { move-column-left; }
    Super+Shift+Right { move-column-right; }
    Super+Shift+Up    { move-window-up; }
    Super+Shift+Down  { move-window-down; }

    // Workspaces (1-10, where 0 = 10)
    Super+1 { focus-workspace 1; }
    Super+2 { focus-workspace 2; }
    Super+3 { focus-workspace 3; }
    Super+4 { focus-workspace 4; }
    Super+5 { focus-workspace 5; }
    Super+6 { focus-workspace 6; }
    Super+7 { focus-workspace 7; }
    Super+8 { focus-workspace 8; }
    Super+9 { focus-workspace 9; }
    Super+0 { focus-workspace 10; }

    Super+Ctrl+1 { move-column-to-workspace 1; }
    Super+Ctrl+2 { move-column-to-workspace 2; }
    Super+Ctrl+3 { move-column-to-workspace 3; }
    Super+Ctrl+4 { move-column-to-workspace 4; }
    Super+Ctrl+5 { move-column-to-workspace 5; }
    Super+Ctrl+6 { move-column-to-workspace 6; }
    Super+Ctrl+7 { move-column-to-workspace 7; }
    Super+Ctrl+8 { move-column-to-workspace 8; }
    Super+Ctrl+9 { move-column-to-workspace 9; }
    Super+Ctrl+0 { move-column-to-workspace 10; }

    // Column / window sizing
    Super+R { switch-preset-column-width; }
    Super+Ctrl+F { expand-column-to-available-width; }
    Super+Minus { set-column-width "-10%"; }
    Super+Equal { set-column-width "+10%"; }
    Super+Shift+Minus { set-window-height "-10%"; }
    Super+Shift+Equal { set-window-height "+10%"; }

    // Center column
    Super+M { center-column; }

    // Media keys
    XF86AudioRaiseVolume allow-when-locked=true { spawn-sh "wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"; }
    XF86AudioMute        allow-when-locked=true { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"; }
    XF86AudioMicMute     allow-when-locked=true { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle"; }
    XF86MonBrightnessUp   allow-when-locked=true { spawn "brightnessctl" "-e4" "-n2" "set" "5%+"; }
    XF86MonBrightnessDown allow-when-locked=true { spawn "brightnessctl" "-e4" "-n2" "set" "5%-"; }
    XF86AudioNext  allow-when-locked=true { spawn "playerctl" "next"; }
    XF86AudioPause allow-when-locked=true { spawn "playerctl" "play-pause"; }
    XF86AudioPlay  allow-when-locked=true { spawn "playerctl" "play-pause"; }
    XF86AudioPrev  allow-when-locked=true { spawn "playerctl" "previous"; }

    // Screenshot
    Print { screenshot; }
}

// ── Window rules ───────────────────────────────────────────────
window-rule {
    match app-id="brave-browser"
    open-on-workspace "browser"
}

window-rule {
    match app-id="com.mitchellh.ghostty"
    open-on-workspace "terminal"
}

// Layer rules: keep wallpaper stationary
layer-rule {
    match namespace="^swww-daemon$"
    place-within-backdrop true
}
