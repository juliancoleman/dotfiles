// -*- mode: jsonc -*-
{
  "reload_style_on_change": true,
  "margin-top": 8,
  "margin-right": 8,
  "margin-bottom": 8,
  "margin-left": 3,
  "position": "right",
  "layer": "top",
  "modules-left": [ "niri/workspaces" ],
  "modules-center": [ "custom/clock" ],
  "modules-right": [ "privacy", "group/connectivity", "group/hardware", "group/power" ],
  "niri/workspaces": {
    "format": "",
    "on-click": "activate"
  },
  "custom/clock": {
    "exec": "~/.config/waybar/scripts/time_jp.sh",
    "interval": 1,
    "return-type": "json",
    "format": "{text}",
    "justify": "center"
  },
  "privacy": {
    "icon-spacing": 4,
    "icon-size": 13,
    "transition-duration": 150,
    "modules": [
      { "type": "screenshare", "tooltip": true, "tooltip-icon-size": 24 },
      { "type": "audio-out", "tooltip": true, "tooltip-icon-size": 24 },
      { "type": "audio-in", "tooltip": true, "tooltip-icon-size": 24 }
    ]
  },
  "group/connectivity": {
    "orientation": "vertical",
    "modules": [ "bluetooth", "custom/wifi-popover", "custom/audio" ]
  },
  "bluetooth": {
    "format": "󰂯",
    "format-on": "󰂯",
    "format-off": "󰂲",
    "format-no-controller": "",
    "format-connected": "󰂯",
    "tooltip-format": "Not connected",
    "tooltip-format-connected": "{num_connections} connected:\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "  {device_alias}",
    "on-click": "popover-shell bluetooth",
    "on-click-right": "~/.config/waybar/scripts/bluetooth_toggle.sh"
  },
  "group/hardware": {
    "orientation": "vertical",
    "modules": [ "custom/cpu", "custom/mem", "custom/gpu", "custom/disk", "custom/fans" ]
  },
  "custom/battery": {
    "exec": "~/.config/waybar/scripts/battery.sh",
    "interval": 2,
    "return-type": "json",
    "format": "{text}",
    "tooltip": true,
    "justify": "center",
    "class": "hidden"
  },
  "custom/cpu": {
    "exec": "~/.config/waybar/scripts/cpu.sh",
    "interval": 2,
    "return-type": "json",
    "tooltip": true,
    "format": "{icon}",
    "format-icons": { "default": "󰻠" }
  },
  "custom/mem": {
    "exec": "~/.config/waybar/scripts/mem.sh",
    "interval": 2,
    "return-type": "json",
    "tooltip": true,
    "format": "{icon}",
    "format-icons": { "default": "󰍛" }
  },
  "custom/gpu": {
    "exec": "~/.config/waybar/scripts/gpu.sh",
    "interval": 2,
    "return-type": "json",
    "tooltip": true,
    "format": "{icon}",
    "format-icons": { "default": "󰢮" }
  },
  "custom/disk": {
    "exec": "~/.config/waybar/scripts/disk.sh",
    "interval": 10,
    "return-type": "json",
    "tooltip": true,
    "format": "{icon}",
    "format-icons": { "default": "󰋊" }
  },
  "custom/fans": {
    "exec": "~/.config/waybar/scripts/fans.sh",
    "interval": 2,
    "return-type": "json",
    "tooltip": true,
    "format": "{icon}",
    "format-icons": { "default": "󰈐" }
  },
  "custom/audio": {
    "exec": "wpctl status 2>/dev/null | grep -q '\\[MUTED\\]' && echo '{\"text\":\"󰖁\",\"class\":\"muted\"}' || echo '{\"text\":\"󰕾\",\"class\":\"default\"}'",
    "interval": 1,
    "return-type": "json",
    "format": "{text}",
    "justify": "center",
    "on-click": "popover-shell audio",
    "on-click-right": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
    "on-click-middle": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"
  },
  "custom/wifi-popover": {
    "format": "󰤨",
    "format-disconnected": "󰀟",
    "format-off": "󰂲",
    "tooltip": false,
    "on-click": "popover-shell wifi",
    "justify": "center"
  },
  "custom/power": {
    "format": "󰐦",
    "justify": "center",
    "menu": "on-click",
    "menu-file": "$HOME/.config/waybar/custom_modules/power_menu.xml",
    "menu-actions": {
      "suspend": "~/.config/waybar/scripts/sleep.sh",
      "shutdown": "shutdown now",
      "reboot": "reboot",
      "lock": "hyprlock --config $HOME/dotfiles/nixos/niri/hyprlock.conf",
      "logout": "niri msg action quit"
    }
  },
  "group/power": {
    "orientation": "vertical",
    "modules": [ "custom/battery", "custom/power" ]
  },
}
